SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=True

# Job Board APIs - All APIs below are free and don't require authentication
# ArbeitNow - https://www.arbeitnow.com/api/job-board-api
# GitHub Jobs Archive - No key required
# USAJobs.gov - No key required (government jobs)
# Remote.co - No key required (remote jobs)
# The Muse - No key required
# Stack Overflow Jobs - No key required
# Dice - No key required
# AngelList - No key required

# Optional APIs (require API keys)
# JSearch (RapidAPI) - https://rapidapi.com/laimoon/api/jsearch
JSEARCH_API_KEY=your-jsearch-api-key

# Adzuna - https://developer.adzuna.com/
ADZUNA_API_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key

# Reed - https://www.reed.co.uk/api
REED_API_KEY=your-reed-api-key
# Get it at: https://jobs.github.com/positions.json

# AI/LLM
OPENAI_API_KEY=your-openai-key
